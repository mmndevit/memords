# Supabase credentials — copy this file to `.env.local` and fill in the values
# from your project's API settings (https://app.supabase.com → Project Settings
# → API). The anon key is a public, browser-safe key; access is controlled by
# the row-level security policies in supabase/schema.sql.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
